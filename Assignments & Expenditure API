// routes/assignment.js
const express = require('express');
const router = express.Router();
const pool = require('../db');
const { logAction } = require('../utils/logger');

router.post('/assign', async (req, res) => {
  const { base_id, personnel_id, equipment_type_id, quantity } = req.body;

  const result = await pool.query(
    `INSERT INTO assignments(base_id, personnel_id, equipment_type_id, quantity, assigned_at)
     VALUES ($1,$2,$3,$4,NOW()) RETURNING *`,
    [base_id, personnel_id, equipment_type_id, quantity]
  );

  await logAction(req.user.id, "ASSIGN", JSON.stringify(result.rows[0]));
  res.json(result.rows[0]);
});

router.post('/expend', async (req, res) => {
  const { base_id, equipment_type_id, quantity } = req.body;

  const result = await pool.query(
    `INSERT INTO expenditures(base_id, equipment_type_id, quantity, timestamp)
     VALUES ($1,$2,$3,NOW()) RETURNING *`,
    [base_id, equipment_type_id, quantity]
  );

  await logAction(req.user.id, "EXPEND", JSON.stringify(result.rows[0]));
  res.json(result.rows[0]);
});

module.exports = router;
